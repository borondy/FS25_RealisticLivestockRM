<!--
    Bridge animals for Hof Bergmann map (FS25_HofBergmann).

    This file serves two purposes:
    1. NEW SUBTYPES: Adds male subtypes to exotic animal types (DUCK_MALE, GOOSE_MALE, TOMCAT)
    2. PROPERTY OVERRIDES: Patches properties on existing types/subtypes from earlier layers
       (base game, RLRM, map) - e.g. fixing incorrect weights, reproduction ages, pregnancy counts.

    Property override rules:
    - Only explicitly defined properties are overridden (omitted = keep current value)
    - Works for both type-level (pregnancy, fertility) and subtype-level (weights, reproduction) properties
    - Same XML structure as animals.xml - no special tags needed
-->
<animals>

    <!-- DUCK_MALE: male variant for DUCK subtype under CHICKEN type -->
    <!-- DUCK uses visualAnimalIndex 4 (duckling) and 5 (adult) in map's chicken config -->
    <animal type="CHICKEN">
        <subType subType="DUCK_MALE" fillTypeName="DUCK_MALE" gender="male" breed="DUCK"
                 minWeight="1.0" targetWeight="3.5" maxWeight="5.5">
            <visuals>
                <visual minAge="0" visualAnimalIndex="4" image="character/animals/domesticated/chicken/store_duckling.png" name="$l10n_rl_bridge_drakeDuckling" canBeBought="false">
                    <description>$l10n_rl_bridge_drakeDucklingDesc</description>
                </visual>
                <visual minAge="6" visualAnimalIndex="5" image="character/animals/domesticated/chicken/store_duck.png" name="$l10n_rl_bridge_drakeAdult" canBeBought="true">
                    <description>$l10n_rl_bridge_drakeAdultDesc</description>
                </visual>
            </visuals>
            <reproduction supported="false" minAgeMonth="6"/>
            <buyPrice>
                <key ageMonth="0" value="30"/>
                <key ageMonth="6" value="65"/>
            </buyPrice>
            <sellPrice>
                <key ageMonth="0" value="15"/>
                <key ageMonth="6" value="35"/>
            </sellPrice>
            <transportPrice>
                <key ageMonth="0" value="5"/>
                <key ageMonth="6" value="10"/>
            </transportPrice>
            <input>
                <food>
                    <key ageMonth="0" value="5"/>
                    <key ageMonth="6" value="5"/>
                </food>
                <straw>
                    <key ageMonth="0" value="5"/>
                    <key ageMonth="6" value="5"/>
                </straw>
                <water>
                    <key ageMonth="0" value="1"/>
                    <key ageMonth="6" value="1"/>
                </water>
            </input>
        </subType>
    </animal>

    <!-- GOOSE: new male subtype + weight fix for existing female -->
    <!-- Map navMesh (h=0.6, r=0.2) gives absurd derived weights: max=90kg, target=36kg -->
    <!-- Real domestic geese: 4-7kg female, 5-10kg male -->
    <animal type="GOOSE">
        <pregnancy average="3" max="6"/>

        <!-- Override: fix existing GOOSE (female) weights from navMesh-derived values -->
        <subType subType="GOOSE" minWeight="0.5" targetWeight="5.0" maxWeight="8.0"/>

        <!-- New: GOOSE_MALE -->
        <subType subType="GOOSE_MALE" fillTypeName="GOOSE_MALE" gender="male" breed="GOOSE"
                 minWeight="0.5" targetWeight="6.5" maxWeight="11.0">
            <visuals>
                <visual minAge="0" visualAnimalIndex="1" image="character/animals/domesticated/goose/store_gooseYoung.png" name="$l10n_rl_bridge_ganderYoung" canBeBought="false">
                    <description>$l10n_rl_bridge_ganderYoungDesc</description>
                </visual>
                <visual minAge="10" visualAnimalIndex="2" image="character/animals/domesticated/goose/store_goose.png" name="$l10n_rl_bridge_ganderAdult" canBeBought="true">
                    <description>$l10n_rl_bridge_ganderAdultDesc</description>
                </visual>
            </visuals>
            <reproduction supported="false" minAgeMonth="10"/>
            <buyPrice>
                <key ageMonth="0" value="25"/>
                <key ageMonth="12" value="55"/>
            </buyPrice>
            <sellPrice>
                <key ageMonth="0" value="15"/>
                <key ageMonth="12" value="30"/>
            </sellPrice>
            <transportPrice>
                <key ageMonth="0" value="2"/>
                <key ageMonth="12" value="2"/>
            </transportPrice>
            <input>
                <food>
                    <key ageMonth="0" value="15"/>
                    <key ageMonth="12" value="45"/>
                </food>
                <straw>
                    <key ageMonth="0" value="5"/>
                    <key ageMonth="12" value="50"/>
                </straw>
                <water>
                    <key ageMonth="0" value="1"/>
                    <key ageMonth="12" value="1"/>
                </water>
            </input>
        </subType>
    </animal>

    <!-- CAT: new male subtype + pregnancy override -->
    <!-- Default pregnancy avg=1, max=3 - real cats have 3-5 kittens per litter -->
    <!-- CAT uses visualAnimalIndex 1 (kitten) and 2 (adult) -->
    <animal type="CAT">
        <pregnancy average="3" max="6"/>

        <!-- New: TOMCAT -->
        <subType subType="TOMCAT" fillTypeName="TOMCAT" gender="male" breed="TOMCAT"
                 minWeight="0.1" targetWeight="4.0" maxWeight="7.0">
            <visuals>
                <visual minAge="0" visualAnimalIndex="1" image="character/animals/domesticated/cat/store_kitten.png" name="$l10n_rl_bridge_tomcatKitten" canBeBought="false">
                    <description>$l10n_rl_bridge_tomcatKittenDesc</description>
                </visual>
                <visual minAge="8" visualAnimalIndex="2" image="character/animals/domesticated/cat/store_femaleCatTiger.png" name="$l10n_rl_bridge_tomcatAdult" canBeBought="true">
                    <description>$l10n_rl_bridge_tomcatAdultDesc</description>
                </visual>
            </visuals>
            <reproduction supported="false" minAgeMonth="8"/>
            <buyPrice>
                <key ageMonth="0" value="30"/>
                <key ageMonth="8" value="100"/>
            </buyPrice>
            <sellPrice>
                <key ageMonth="0" value="15"/>
                <key ageMonth="8" value="50"/>
            </sellPrice>
            <transportPrice>
                <key ageMonth="0" value="5"/>
                <key ageMonth="8" value="5"/>
            </transportPrice>
            <input>
                <food>
                    <key ageMonth="0" value="3"/>
                    <key ageMonth="8" value="5"/>
                </food>
                <water>
                    <key ageMonth="0" value="1"/>
                    <key ageMonth="8" value="1"/>
                </water>
            </input>
        </subType>
    </animal>

    <!-- RABBIT: override reproduction age for existing RABBIT_MALE + pregnancy -->
    <!-- Map sets RABBIT_MALE reproduction supported="false" with no minAgeMonth → defaults to 18 -->
    <!-- Real rabbits mature at 3-4 months; 6 months is conservative -->
    <!-- Default pregnancy avg=1, max=3 - real rabbits have 4-8 kits per litter -->
    <animal type="RABBIT">
        <pregnancy average="4" max="8"/>

        <!-- Override: fix RABBIT weights (navMesh h=0.1, r=0.1 gives max=7.5 - refine) -->
        <subType subType="RABBIT" minWeight="0.1" targetWeight="2.5" maxWeight="5.0"/>

        <!-- Override: fix RABBIT_MALE reproduction age from default 18 → 6 months -->
        <subType subType="RABBIT_MALE" minWeight="0.1" targetWeight="3.0" maxWeight="5.5">
            <reproduction minAgeMonth="6"/>
        </subType>
    </animal>

    <!--
        Breeding groups: subtypes in the same group can ONLY breed with each other.
        Subtypes not in any group follow base game rules.
        maxFertilityAge: max age in months for male fertility (overrides base fallback).
    -->
    <breedingGroups>
        <group name="DUCK" maxFertilityAge="36">
            <subType name="DUCK"/>
            <subType name="DUCK_MALE"/>
        </group>
    </breedingGroups>

    <!--
        HORSE type: HB uses interleaved foal/adult entries (4 breeds x 2 stages = 8 entries).
        Base game: 8 flat entries (1 per breed, adult model only, 4x2 texture atlas).
        HB:        [1]=Gray foal, [2]=Gray adult, [3]=Palomino foal, [4]=Palomino adult,
                   [5]=Black foal, [6]=Black adult, [7]=Seal Brown foal, [8]=Seal Brown adult

        RLRM Phase 1 defines 8 breeds (16 subtypes with gender) using flat indices 1-8.
        Bridge remaps to HB's interleaved layout with 2-stage foal/adult visuals.
        HB only has models for 4 breeds; the other 4 map to visually similar breeds:
        Pinto->Gray, Chestnut->Seal Brown, Bay->Seal Brown, Dun->Palomino.
    -->
    <animal type="HORSE">
        <!-- Native HB breeds: Gray (foal=1, adult=2) -->
        <subType subType="HORSE_GRAY">
            <visuals>
                <visual minAge="0" visualAnimalIndex="1" image="character/animals/domesticated/horse/store_foalGray.png" canBeBought="true"/>
                <visual minAge="12" visualAnimalIndex="2" image="$dataS/character/animals/domesticated/horse/store_horseGray.png" canBeBought="true"/>
            </visuals>
        </subType>
        <subType subType="STALLION_GRAY">
            <visuals>
                <visual minAge="0" visualAnimalIndex="1" image="character/animals/domesticated/horse/store_foalGray.png" canBeBought="true"/>
                <visual minAge="12" visualAnimalIndex="2" image="$dataS/character/animals/domesticated/horse/store_horseGray.png" canBeBought="true"/>
            </visuals>
        </subType>

        <!-- Native HB breeds: Palomino (foal=3, adult=4) -->
        <subType subType="HORSE_PALOMINO">
            <visuals>
                <visual minAge="0" visualAnimalIndex="3" image="character/animals/domesticated/horse/store_foalPalomino.png" canBeBought="true"/>
                <visual minAge="12" visualAnimalIndex="4" image="$dataS/character/animals/domesticated/horse/store_horsePalomino.png" canBeBought="true"/>
            </visuals>
        </subType>
        <subType subType="STALLION_PALOMINO">
            <visuals>
                <visual minAge="0" visualAnimalIndex="3" image="character/animals/domesticated/horse/store_foalPalomino.png" canBeBought="true"/>
                <visual minAge="12" visualAnimalIndex="4" image="$dataS/character/animals/domesticated/horse/store_horsePalomino.png" canBeBought="true"/>
            </visuals>
        </subType>

        <!-- Native HB breeds: Black (foal=5, adult=6) -->
        <subType subType="HORSE_BLACK">
            <visuals>
                <visual minAge="0" visualAnimalIndex="5" image="character/animals/domesticated/horse/store_foalBlack.png" canBeBought="true"/>
                <visual minAge="12" visualAnimalIndex="6" image="$dataS/character/animals/domesticated/horse/store_horseBlack.png" canBeBought="true"/>
            </visuals>
        </subType>
        <subType subType="STALLION_BLACK">
            <visuals>
                <visual minAge="0" visualAnimalIndex="5" image="character/animals/domesticated/horse/store_foalBlack.png" canBeBought="true"/>
                <visual minAge="12" visualAnimalIndex="6" image="$dataS/character/animals/domesticated/horse/store_horseBlack.png" canBeBought="true"/>
            </visuals>
        </subType>

        <!-- Native HB breeds: Seal Brown (foal=7, adult=8) -->
        <subType subType="HORSE_SEAL_BROWN">
            <visuals>
                <visual minAge="0" visualAnimalIndex="7" image="character/animals/domesticated/horse/store_foalSealBrown.png" canBeBought="true"/>
                <visual minAge="12" visualAnimalIndex="8" image="$dataS/character/animals/domesticated/horse/store_horseSealBrown.png" canBeBought="true"/>
            </visuals>
        </subType>
        <subType subType="STALLION_SEAL_BROWN">
            <visuals>
                <visual minAge="0" visualAnimalIndex="7" image="character/animals/domesticated/horse/store_foalSealBrown.png" canBeBought="true"/>
                <visual minAge="12" visualAnimalIndex="8" image="$dataS/character/animals/domesticated/horse/store_horseSealBrown.png" canBeBought="true"/>
            </visuals>
        </subType>

        <!-- Unsupported breeds: not purchasable on HB (no native 3D models).
             Visual indices map to closest HB breed for existing savegame animals. -->

        <!-- Pinto -> Gray visual (not purchasable) -->
        <subType subType="HORSE_PINTO">
            <visuals>
                <visual minAge="0" visualAnimalIndex="1" image="character/animals/domesticated/horse/store_foalGray.png" canBeBought="false"/>
                <visual minAge="12" visualAnimalIndex="2" image="$dataS/character/animals/domesticated/horse/store_horsePinto.png" canBeBought="false"/>
            </visuals>
        </subType>
        <subType subType="STALLION_PINTO">
            <visuals>
                <visual minAge="0" visualAnimalIndex="1" image="character/animals/domesticated/horse/store_foalGray.png" canBeBought="false"/>
                <visual minAge="12" visualAnimalIndex="2" image="$dataS/character/animals/domesticated/horse/store_horsePinto.png" canBeBought="false"/>
            </visuals>
        </subType>

        <!-- Chestnut -> Seal Brown visual (not purchasable) -->
        <subType subType="HORSE_CHESTNUT">
            <visuals>
                <visual minAge="0" visualAnimalIndex="7" image="character/animals/domesticated/horse/store_foalSealBrown.png" canBeBought="false"/>
                <visual minAge="12" visualAnimalIndex="8" image="$dataS/character/animals/domesticated/horse/store_horseChestnut.png" canBeBought="false"/>
            </visuals>
        </subType>
        <subType subType="STALLION_CHESTNUT">
            <visuals>
                <visual minAge="0" visualAnimalIndex="7" image="character/animals/domesticated/horse/store_foalSealBrown.png" canBeBought="false"/>
                <visual minAge="12" visualAnimalIndex="8" image="$dataS/character/animals/domesticated/horse/store_horseChestnut.png" canBeBought="false"/>
            </visuals>
        </subType>

        <!-- Bay -> Seal Brown visual (not purchasable) -->
        <subType subType="HORSE_BAY">
            <visuals>
                <visual minAge="0" visualAnimalIndex="7" image="character/animals/domesticated/horse/store_foalSealBrown.png" canBeBought="false"/>
                <visual minAge="12" visualAnimalIndex="8" image="$dataS/character/animals/domesticated/horse/store_horseBay.png" canBeBought="false"/>
            </visuals>
        </subType>
        <subType subType="STALLION_BAY">
            <visuals>
                <visual minAge="0" visualAnimalIndex="7" image="character/animals/domesticated/horse/store_foalSealBrown.png" canBeBought="false"/>
                <visual minAge="12" visualAnimalIndex="8" image="$dataS/character/animals/domesticated/horse/store_horseBay.png" canBeBought="false"/>
            </visuals>
        </subType>

        <!-- Dun -> Palomino visual (not purchasable) -->
        <subType subType="HORSE_DUN">
            <visuals>
                <visual minAge="0" visualAnimalIndex="3" image="character/animals/domesticated/horse/store_foalPalomino.png" canBeBought="false"/>
                <visual minAge="12" visualAnimalIndex="4" image="$dataS/character/animals/domesticated/horse/store_horseDun.png" canBeBought="false"/>
            </visuals>
        </subType>
        <subType subType="STALLION_DUN">
            <visuals>
                <visual minAge="0" visualAnimalIndex="3" image="character/animals/domesticated/horse/store_foalPalomino.png" canBeBought="false"/>
                <visual minAge="12" visualAnimalIndex="4" image="$dataS/character/animals/domesticated/horse/store_horseDun.png" canBeBought="false"/>
            </visuals>
        </subType>
    </animal>

    <!--
        Config overrides: update animalType.configFilename for types where the map's
        3D model config has additional models beyond the base game config.
        Without this, the C++ engine only loads base game models and map-specific
        visual indices (e.g. duck models at index 4-5) cause "invalid animal subtype" errors.
    -->
    <configOverrides>
        <override type="CHICKEN" configFilename="character/animals/domesticated/chicken/husbandryAnimalsChicken.xml"/>
        <override type="HORSE" configFilename="character/animals/domesticated/horse/husbandryAnimalsHorse.xml"/>
    </configOverrides>

</animals>
