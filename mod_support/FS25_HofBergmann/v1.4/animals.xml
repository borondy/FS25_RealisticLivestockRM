            </input>
        </subType>
    </animal>

    <!-- DUCKWILD: new male subtype (RLRM-116) -->
    <!-- Wild ducks use the same duck visual config as DUCK -->
    <animal type="DUCKWILD">
        <!-- Override: set breed on existing female for breeding group compatibility -->
        <subType subType="DUCKWILD" breed="DUCKWILD"/>

        <!-- New: DUCKWILD_MALE -->
        <subType subType="DUCKWILD_MALE" fillTypeName="DUCKWILD_MALE" gender="male" breed="DUCKWILD"
                 minWeight="1.0" targetWeight="3.5" maxWeight="5.5">
            <visuals>
                <visual minAge="0" visualAnimalIndex="1"
                        image="character/animals/domesticated/chicken/store_duckling.png"
                        name="$l10n_rl_bridge_duckwildMaleYoung" canBeBought="false">
                    <description>$l10n_rl_bridge_duckwildMaleYoungDesc</description>
                </visual>
                <visual minAge="6" visualAnimalIndex="2"
                        image="character/animals/domesticated/chicken/store_duck.png"
                        name="$l10n_rl_bridge_duckwildMaleAdult" canBeBought="true">
                    <description>$l10n_rl_bridge_duckwildMaleAdultDesc</description>
                </visual>
            </visuals>
            <reproduction supported="false" minAgeMonth="6"/>
            <buyPrice>
                <key ageMonth="0" value="30"/>
                <key ageMonth="6" value="65"/>
            </buyPrice>
            <sellPrice>
                <key ageMonth="0" value="15"/>
                <key ageMonth="6" value="35"/>
            </sellPrice>
            <transportPrice>
                <key ageMonth="0" value="5"/>
                <key ageMonth="6" value="10"/>
            </transportPrice>
            <input>
                <food>
                    <key ageMonth="0" value="5"/>
                    <key ageMonth="6" value="5"/>
                </food>
                <straw>
                    <key ageMonth="0" value="5"/>
                    <key ageMonth="6" value="5"/>
                </straw>
                <water>
                    <key ageMonth="0" value="1"/>
                    <key ageMonth="6" value="1"/>
                </water>
            </input>
        </subType>
    </animal>

    <!--
        Breeding groups: subtypes in the same group can ONLY breed with each other.
        Subtypes not in any group follow base game rules.
        maxFertilityAge: max age in months for male fertility (overrides base fallback).
    -->
    <breedingGroups>
        <group name="DUCK" maxFertilityAge="36">
            <subType name="DUCK"/>
            <subType name="DUCK_MALE"/>
        </group>
        <group name="ALPACA" maxFertilityAge="180">
            <subType name="ALPACA_WHITE"/>
            <subType name="ALPACA_WHITE_MALE"/>
            <subType name="ALPACA_BROWN"/>
            <subType name="ALPACA_BROWN_MALE"/>
            <subType name="ALPACA_BLACK"/>
            <subType name="ALPACA_BLACK_MALE"/>
            <subType name="ALPACA_GREY"/>
            <subType name="ALPACA_GREY_MALE"/>
        </group>
        <group name="QUAIL" maxFertilityAge="24">
            <subType name="QUAIL"/>
            <subType name="QUAIL_MALE"/>
        </group>
        <group name="DUCKWILD" maxFertilityAge="36">
            <subType name="DUCKWILD"/>
            <subType name="DUCKWILD_MALE"/>
        </group>
    </breedingGroups>

    <!--
        Config overrides: update animalType.configFilename for types where the map's
        3D model config has additional models beyond the base game config.
        Without this, the C++ engine only loads base game models and map-specific
        visual indices (e.g. duck models at index 5-6) cause "invalid animal subtype" errors.
    -->
    <configOverrides>
        <override type="CHICKEN" configFilename="character/animals/domesticated/chicken/husbandryAnimalsChicken.xml"/>
    </configOverrides>

</animals>
