            <buyPrice>
                <key ageMonth="0" value="3000"/>
                <key ageMonth="3" value="3000"/>
                <key ageMonth="8" value="6000"/>
            </buyPrice>
            <sellPrice>
                <key ageMonth="0" value="2500"/>
                <key ageMonth="3" value="2500"/>
                <key ageMonth="8" value="5000"/>
            </sellPrice>
            <transportPrice>
                <key ageMonth="0" value="20"/>
                <key ageMonth="3" value="20"/>
                <key ageMonth="8" value="50"/>
