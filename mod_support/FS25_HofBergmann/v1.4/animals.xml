    <!-- QUAIL: new male subtype -->
    <!-- Real quail: 120-180g male, slightly smaller than female -->
    <animal type="QUAIL">
        <!-- Override: set breed on existing female for breeding group compatibility -->
        <subType subType="QUAIL" breed="QUAIL"/>

        <!-- New: QUAIL_MALE -->
        <subType subType="QUAIL_MALE" fillTypeName="QUAIL_MALE" gender="male" breed="QUAIL"
                 minWeight="0.05" targetWeight="0.15" maxWeight="0.2">
            <visuals>
                <visual minAge="0" visualAnimalIndex="1"
                        image="character/animals/domesticated/chicken/store_quail.png"
                        name="$l10n_rl_bridge_quailMaleYoung" canBeBought="false">
                    <description>$l10n_rl_bridge_quailMaleYoungDesc</description>
                </visual>
                <visual minAge="6" visualAnimalIndex="1"
                        image="character/animals/domesticated/chicken/store_quail.png"
                        name="$l10n_rl_bridge_quailMaleAdult" canBeBought="true">
                    <description>$l10n_rl_bridge_quailMaleAdultDesc</description>
                </visual>
            </visuals>
            <reproduction supported="false" minAgeMonth="6"/>
            <buyPrice>
                <key ageMonth="0" value="6"/>
                <key ageMonth="6" value="12"/>
            </buyPrice>
            <sellPrice>
                <key ageMonth="0" value="5"/>
                <key ageMonth="6" value="25"/>
            </sellPrice>
            <transportPrice>
                <key ageMonth="0" value="1"/>
