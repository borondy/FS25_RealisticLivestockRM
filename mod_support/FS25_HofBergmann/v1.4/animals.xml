            </sellPrice>
            <transportPrice>
                <key ageMonth="0" value="20"/>
                <key ageMonth="3" value="20"/>
                <key ageMonth="8" value="50"/>
            </transportPrice>
            <input>
                <food>
                    <key ageMonth="0" value="5"/>
                    <key ageMonth="3" value="5"/>
                    <key ageMonth="8" value="50"/>
                </food>
                <straw>
