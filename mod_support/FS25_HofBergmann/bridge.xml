<!--
    Version entries can be exact strings ("1.4.0.0 Beta1") or range specifiers (">=1.3.0.1,<1.4.0.0").
    Specifiers use operators: >=, <=, >, <, ==, != with comma-separated AND logic.
    NOTE: XML requires < to be escaped as &lt; inside attribute values.
-->
<bridge>
    <configs>
        <config id="v1.3" path="v1.3/">
            <supportedVersions>
                <version value=">=1.3.0.1,&lt;1.4"/>
            </supportedVersions>
        </config>
        <config id="v1.4" path="v1.4/">
            <supportedVersions>
                <version value="==1.4.b1"/>
                <version value="==1.4.b2"/>
                <version value=">=1.4,&lt;1.5"/>
            </supportedVersions>
        </config>
    </configs>
</bridge>
