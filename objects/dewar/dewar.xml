<?xml version="1.0" encoding="utf-8" standalone="no" ?>
<vehicle type="rlDewar">
    <storeData>
        <name>$l10n_rl_ui_dewar</name>
        <functions>
            <function>$l10n_rl_ui_dewar</function>
        </functions>
        <specs>
            <weight ignore="true"/>
        </specs>
        <allowLeasing>false</allowLeasing>
        <price>0</price>
        <rotation>0</rotation>
        <category>pallets</category>
        <brand>NONE</brand>
        <showInStore>false</showInStore>
        <canBeSold>false</canBeSold>
        <financeCategory>OTHER</financeCategory>
        <shopHeight>0.5</shopHeight>
        <audioMemoryUsage>0</audioMemoryUsage>
    </storeData>

    <base>
        <typeDesc>$l10n_rl_ui_dewar</typeDesc>
        <filename>objects/dewar/dewar.i3d</filename>
        <size width="0.3" length="0.3" height="0.5" />
        <canBeReset>false</canBeReset>
        <supportsPickUp>true</supportsPickUp>
        <components>
            <component centerOfMass="0 0.15 0" solverIterationCount="10" mass="10"/>
        </components>
        <showInVehicleMenu>false</showInVehicleMenu>
        <mapHotspot available="false" />
    </base>

    <tensionBeltObject>
        <meshNodes>
            <meshNode node="dewarMesh"/>
        </meshNodes>
    </tensionBeltObject>

    <!--
        Placeholder zero-capacity fillUnit.

        The dewar carries its payload via DewarData (straws + stored animal),
        not via a fillable content. This placeholder block exists purely so
        the dewar presents the same surface as an ordinary pallet: some
        third-party mods that inspect stored pallets assume a fillUnit is
        always present and crash otherwise (observed with Time Saving
        Stock Check). Capacity 0 with fillType UNKNOWN makes the block inert.
    -->
    <fillUnit>
        <fillUnitConfigurations>
            <fillUnitConfiguration name="$l10n_configuration_valueDefault" price="0">
                <fillUnits>
                    <fillUnit fillTypes="UNKNOWN" capacity="0" unit="$l10n_unit_literShort"
                              showInShop="false" showCapacityInShop="false"
                              updateMass="false" canBeUnloaded="false" />
                </fillUnits>
            </fillUnitConfiguration>
        </fillUnitConfigurations>
    </fillUnit>

    <i3dMappings>
        <i3dMapping id="dewar_main_component1" node="0>" />
        <i3dMapping id="dewarMesh" node="0>0" />
        <i3dMapping id="stickyNote_animal" node="0>0|0" />
        <i3dMapping id="stickyNote_straws" node="0>0|1" />
    </i3dMappings>
</vehicle>
